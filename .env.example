# =============================================================================
# !!! WARNING !!!  THIS FILE IS COMMITTED TO GIT.  NEVER PASTE REAL SECRETS.
#
# This is the example/template only. It contains non-secret runtime settings.
# Live Polymarket credentials belong in credentials/encrypted_credentials.json,
# created with `python setup_vault.py`. Do NOT paste private keys or API secrets
# into this file.
# =============================================================================
#
# Polymarket BTC 15-Min Bot — local simulation/test-mode .env example
#
# Copy this file to `.env` for runtime configuration. Editing `.env` while the
# bot is running has NO effect; `load_dotenv()` runs once at startup. Restart
# the process to pick up changes.
#
# Markers:
#   [per-decision]  Re-read from process env on every trade decision/tick.
#   [startup]       Read once at startup. Restart required to change.
#   [required-live] Must be set in live mode (--live); bot refuses startup otherwise.
#   [optional]      Has a documented default if unset.
# =============================================================================


# ---------------------------------------------------------------------------
# Redis (required for sim/live mode switching)        [startup, required-live]
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2


# ---------------------------------------------------------------------------
# Grafana / Prometheus metrics exporter / logs         [startup]
# ---------------------------------------------------------------------------
# Required Nautilus log directory. The deploy unit sets this to
# /opt/polybot/logs/nautilus.
NAUTILUS_LOG_DIR=./logs/nautilus

# Bind address and port for the in-process Prometheus metrics HTTP server.
# Override these when running multiple bot instances on one host so each gets
# its own port. Unset => prior hardcoded defaults (0.0.0.0 : 8000).
GRAFANA_HOST=0.0.0.0
GRAFANA_PORT=8000

# Decision-observation JSONL path. If unset, the writer resolves
# decisions.jsonl next to LIVE_TRADE_LEDGER_PATH.
#DECISION_LOG_PATH=decisions.jsonl


# ---------------------------------------------------------------------------
# Trading sizing
# ---------------------------------------------------------------------------
# MARKET_BUY_USD must be STRICTLY GREATER THAN 5.50 for live mode (the live
# startup gate blocks exactly 5.50). Smoke-test minimum: 5.51. Operator's
# normal sizing target: 55.00.                       [per-decision, required-live]
#
# This block currently shows the SMOKE-TEST values. After the live smoke
# trade settles cleanly, change to the operator-confirmed production sizing:
#   MARKET_BUY_USD=55.00
#   MAX_POSITION_SIZE=55.00
#   MAX_TOTAL_EXPOSURE=385.00      (= 55.00 * 7 positions)
#   MAX_POSITIONS=7
#   MAX_LOSS_PER_DAY=110.00        (~= 2 losing positions per day)
#   MAX_DRAWDOWN_PCT=0.15
#
# Sizing invariants the operator must keep consistent when changing these:
#   - MAX_POSITION_SIZE >= MARKET_BUY_USD
#   - MAX_TOTAL_EXPOSURE >= MAX_POSITION_SIZE * MAX_POSITIONS
MARKET_BUY_USD=5.51

# Risk-engine caps. Read once at __init__; restart to change.   [startup]
MAX_POSITION_SIZE=5.51
MAX_TOTAL_EXPOSURE=22.04
MAX_POSITIONS=4
MAX_DRAWDOWN_PCT=0.15
MAX_LOSS_PER_DAY=11.02

# Required startup acknowledgement for the UTC daily-risk reset boundary.
# Set only after reviewing docs/RAW_DECISION_SNAPSHOT_OPERATIONS.md.
POLYBOT_ACKNOWLEDGE_UTC_DAILY_RESET=1


# ---------------------------------------------------------------------------
# Order-type selection                             [startup/decision, required]
# ---------------------------------------------------------------------------
# Allowed values: market_ioc | limit_ioc
# market_ioc: explicit operator acceptance of book-sweep price risk.
# limit_ioc: routine live-resume path; requires LIMIT_REQUIRED_EDGE and
#   LIMIT_IOC_FILL_POLICY below.
# Set explicitly for all order-capable runs. Routine resume uses limit_ioc.
ORDER_TYPE=limit_ioc

# Required for order-capable runs. Number of consecutive valid quote ticks after
# a market switch/reset before any order decision can proceed.
QUOTE_STABILITY_REQUIRED=3

# Required when ORDER_TYPE=limit_ioc.       [startup, conditionally required]
# Decimal in (0, 1). Edge above what we'll pay at the order-placement cap.
# Operator should set LIMIT_REQUIRED_EDGE >= EV_FEE_BUFFER + EV_SPREAD_BUFFER
# so orders that pass the limit step also have a reasonable chance of passing
# the EV gate.
LIMIT_REQUIRED_EDGE=0.05

# Required when ORDER_TYPE=limit_ioc.       [startup, conditionally required]
# Allowed values: partial_ok | all_or_nothing
# Current Nautilus IOC wire mapping is Polymarket FAK, so routine limit_ioc
# resume must use partial_ok unless a verified FOK path is implemented.
LIMIT_IOC_FILL_POLICY=partial_ok


# ---------------------------------------------------------------------------
# Sizing mode selection                               [startup, required-live]
# ---------------------------------------------------------------------------
# Allowed values: fixed | percent
# fixed: uses MARKET_BUY_USD as the per-trade spend (current behavior).
# percent: requires PCT_OF_FREE_COLLATERAL_PER_TRADE below.
SIZING_MODE=fixed

# Required when SIZING_MODE=percent.        [startup, conditionally required]
# Decimal in (0, 1). E.g. 0.05 = use 5% of free collateral per trade.
#PCT_OF_FREE_COLLATERAL_PER_TRADE=0.05

# Required in live mode for both sizing modes. The bot refuses live order
# submission until a fresh Polymarket AccountState has reported pUSD free
# collateral. After order submission/fill/redeem, this cache is marked stale
# until a newer AccountState arrives.
MAX_ACCOUNT_STATE_AGE_SECONDS=30
BALANCE_SAFETY_BUFFER_USD=0.00

# Required in live mode. Reject live decisions if the frozen quote/history
# snapshot ages past this threshold before order side effects.
MAX_DECISION_SNAPSHOT_AGE_SECONDS=10


# ---------------------------------------------------------------------------
# Signal/decision tuning                              [per-decision]
# ---------------------------------------------------------------------------
REQUIRE_SIGNAL_CONFIRMATION=true
MIN_SIGNAL_CONFIDENCE=0.70
EV_FEE_BUFFER=0.005
EV_SPREAD_BUFFER=0.01

# Promoted signal/fusion constants. These are required at startup and are
# captured into effective decision config for replay/calibration.
LIQUIDITY_FLOOR=0.02
FUSION_RECENCY_WINDOW_SECONDS=300
FUSION_MIN_SIGNALS=2
FUSION_MIN_SCORE=55.0
TREND_UP_THRESHOLD=0.60
TREND_DOWN_THRESHOLD=0.40
DIVERGENCE_SPOT_HISTORY_MAX_LEN=100
TICK_VELOCITY_TOLERANCE_SECONDS=5


# ---------------------------------------------------------------------------
# Settlement / reconciliation                         [per-decision / per-event]
# ---------------------------------------------------------------------------
LIVE_SETTLEMENT_GRACE_SECONDS=3600
REQUIRE_AUTO_REDEEM_TOKEN_HINT=true
LIVE_TRADE_LEDGER_PATH=live_trades.json


# ---------------------------------------------------------------------------
# Raw decision snapshot capture                         [startup / optional]
# ---------------------------------------------------------------------------
# Capture is disabled unless RAW_DECISION_SNAPSHOT_DIR is set. When enabling
# capture, set POLYBOT_GIT_SHA from the exact deployed revision.
#RAW_DECISION_SNAPSHOT_DIR=./raw_decision_snapshots
#POLYBOT_GIT_SHA=<git-sha>

# Store Deribit raw option summaries in snapshots. Default behavior stores
# hashes/diagnostics only.
#RAW_DECISION_SNAPSHOT_INCLUDE_DERIBIT_RAW=1


# =============================================================================
# Env vars that are NOT read by the bot — do NOT add them to .env. They have
# zero effect at runtime.
#
#   STOP_LOSS_PCT, TAKE_PROFIT_PCT
#       The bot has no per-position exit loop and Polymarket does not support
#       stop orders. Wiring these would require building a polling exit loop
#       (out of scope).
#
#   SPIKE_THRESHOLD, DIVERGENCE_THRESHOLD
#       Code-owned constants in bot.py (both 0.05). Reading from env was
#       intentionally not wired; these are kept as
#       code-owned. To adjust, edit bot.py and restart.
# =============================================================================
