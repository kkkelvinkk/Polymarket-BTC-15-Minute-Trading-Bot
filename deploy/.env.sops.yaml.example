# SOPS template — encrypted env example.
#
# This file is the SHAPE only; the values shown are placeholders. Encrypt your
# real .env into this format with:
#
#   sops --encrypt --age <your-age-recipient> .env > .env.sops.yaml
#
# Then launch the bot via the systemd unit's sops exec-env ExecStart line
# (see deploy/polybot.service for the SOPS variant).
#
# Plaintext .env is incompatible with live mode after SOPS is adopted —
# the bot's module-level check refuses to start in --live with a plaintext
# .env present at the repo root. See the Pattern A section in EXECUTION_PLAN.md.

POLYMARKET_PK: <encrypted-private-key>
POLYMARKET_FUNDER: <encrypted-funder-address>
POLYMARKET_SIGNATURE_TYPE: "3"
POLYMARKET_API_KEY: <encrypted-api-key>
POLYMARKET_API_SECRET: <encrypted-api-secret>
POLYMARKET_PASSPHRASE: <encrypted-passphrase>
REDIS_HOST: localhost
REDIS_PORT: "6379"
REDIS_DB: "2"
NAUTILUS_LOG_DIR: /opt/polybot/logs/nautilus
MARKET_BUY_USD: "55.00"
MAX_POSITION_SIZE: "55.00"
MAX_TOTAL_EXPOSURE: "385.00"
MAX_POSITIONS: "7"
MAX_DRAWDOWN_PCT: "0.15"
MAX_LOSS_PER_DAY: "110.00"
SIZING_MODE: fixed
MAX_ACCOUNT_STATE_AGE_SECONDS: "30"
BALANCE_SAFETY_BUFFER_USD: "0.00"
MAX_DECISION_SNAPSHOT_AGE_SECONDS: "10"
REQUIRE_SIGNAL_CONFIRMATION: "true"
MIN_SIGNAL_CONFIDENCE: "0.70"
EV_FEE_BUFFER: "0.005"
EV_SPREAD_BUFFER: "0.01"
ORDER_TYPE: limit_ioc
QUOTE_STABILITY_REQUIRED: "3"
LIMIT_REQUIRED_EDGE: "0.05"
LIMIT_IOC_FILL_POLICY: partial_ok
LIVE_SETTLEMENT_GRACE_SECONDS: "3600"
REQUIRE_AUTO_REDEEM_TOKEN_HINT: "true"
LIVE_TRADE_LEDGER_PATH: /opt/polybot/ledger/live_trades.json
DECISION_LOG_PATH: /opt/polybot/ledger/decisions.jsonl
POLYGON_RPC_URL: https://your-polygon-rpc.example

sops:
  age:
    - recipient: <your-age-recipient-here>
      enc: |
        -----BEGIN AGE ENCRYPTED FILE-----
        <encrypted-data-key>
        -----END AGE ENCRYPTED FILE-----
  lastmodified: "2026-05-19T00:00:00Z"
  mac: ENC[AES256_GCM,data:...,iv:...,tag:...,type:str]
  pgp: []
  unencrypted_suffix: _unencrypted
  version: 3.7.3
